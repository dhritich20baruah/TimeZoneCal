---
import BaseLayout from '../layouts/BaseLayout.astro';
import TimezoneConverter from '../components/TimezoneConverter.astro';

const features = ['All 38 timezones', 'DST-aware', 'Live world clocks', 'Copy to clipboard', 'No sign-up needed'];

const steps = [
  { step: '1', title: 'Pick your timezones', body: 'Choose any origin and destination timezone from the dropdowns — 20 major cities covered.' },
  { step: '2', title: 'Set the date & time', body: 'Enter a specific date and time, or use the quick-select shortcuts for common moments.' },
  { step: '3', title: 'See the result instantly', body: 'The converted time appears immediately, including the date and hour offset between zones.' },
];

const pageLinks = [
  { href: '/about',          label: 'About us',           sub: 'Who we are' },
  { href: '/contact',        label: 'Contact us',          sub: 'Get in touch' },
  { href: '/privacy-policy', label: 'Privacy policy',      sub: 'How we handle data' },
  { href: '/terms',          label: 'Terms & conditions',  sub: 'Usage rules' },
];
---

<BaseLayout 
  title="Best Time Zone Converter · Compare World Time Instantly" 
  description="Use our free time zone converter to compare multiple time zones, calculate time differences, and convert between UTC, Pacific Time, and more. Fast, accurate, and easy."
  keywords="time zone converter, pacific time zone converter, UTC time zone converter, time zone converter calculator, world time converter, multiple time zone converter, time difference calculator"
>

  <!-- ─── Hero ─── -->
  <div style="background:var(--color-surface-soft); border-bottom:1px solid var(--color-hairline-soft); padding:var(--spacing-section) var(--spacing-base);">
    <div style="max-width:var(--width-page); margin:0 auto;">
      <h1 style="font-size:32px; font-weight:800; color:var(--color-ink); line-height:1.2; margin-bottom:var(--spacing-sm);">
        The Ultimate Time Zone Converter & Calculator
      </h1>
      <p style="font-size:18px; color:var(--color-muted); line-height:1.6; max-width:600px; margin-bottom:var(--spacing-lg);">
        Convert time between any two locations instantly. Our world time converter makes it easy to stay in sync with global teams and events.
      </p>

      <!-- Feature pills -->
      <div class="flex flex-wrap gap-2">
        {features.map(f => (
          <span style="display:inline-flex; align-items:center; gap:6px; background:var(--color-canvas); border:1px solid var(--color-hairline); border-radius:var(--radius-full); padding:6px 14px; font-size:14px; font-weight:500; color:var(--color-body);" class="shadow-card">
            <svg width="8" height="8" viewBox="0 0 8 8" fill="var(--color-rausch)" aria-hidden="true"><circle cx="4" cy="4" r="4"/></svg>
            {f}
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- ─── Converter ─── -->
  <TimezoneConverter />

  <!-- ─── How it works ─── -->
  <div style="background:var(--color-surface-soft); border-top:1px solid var(--color-hairline-soft); padding:var(--spacing-section) var(--spacing-base);">
    <div style="max-width:var(--width-page); margin:0 auto;">
      <h2 style="font-size:21px; font-weight:700; color:var(--color-ink); margin-bottom:var(--spacing-lg);">How it works</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {steps.map(({ step, title, body }) => (
          <div class="shadow-card" style="background:var(--color-canvas); border:1px solid var(--color-hairline); border-radius:var(--radius-lg); padding:var(--spacing-lg);">
            <div style="width:32px; height:32px; border-radius:var(--radius-full); background:var(--color-rausch); color:white; font-size:12px; font-weight:700; display:flex; align-items:center; justify-content:center; margin-bottom:var(--spacing-md);">
              {step}
            </div>
            <h3 style="font-size:16px; font-weight:600; color:var(--color-ink); margin-bottom:4px;">{title}</h3>
            <p style="font-size:14px; color:var(--color-muted); line-height:1.43;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ─── Page links ─── -->
  <div style="padding:var(--spacing-section) var(--spacing-base);">
    <div style="max-width:var(--width-page); margin:0 auto;">
      <h2 style="font-size:21px; font-weight:700; color:var(--color-ink); margin-bottom:var(--spacing-lg);">Learn more</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {pageLinks.map(({ href, label, sub }) => (
          <a href={href} class="page-link-card" style="display:block; background:var(--color-canvas); border:1px solid var(--color-hairline); border-radius:var(--radius-lg); padding:var(--spacing-lg); text-decoration:none; transition:border-color 0.15s, box-shadow 0.15s;">
            <div style="font-size:16px; font-weight:600; color:var(--color-ink); margin-bottom:4px;">{label}</div>
            <div style="font-size:14px; color:var(--color-muted);">{sub}</div>
            <div style="margin-top:var(--spacing-md); font-size:14px; font-weight:500; color:var(--color-rausch); display:flex; align-items:center; gap:4px; opacity:0; transition:opacity 0.15s;" class="link-arrow">
              View page
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- ─── FAQ Section ─── -->
  <div style="padding:var(--spacing-section) var(--spacing-base); border-top:1px solid var(--color-hairline-soft);">
    <div style="max-width:var(--width-page); margin:0 auto;">
      <h2 style="font-size:24px; font-weight:700; color:var(--color-ink); margin-bottom:var(--spacing-xl);">Frequently Asked Questions</h2>
      
      <div class="flex flex-col gap-6">
        <div class="faq-item">
          <h3 style="font-size:16px; font-weight:600; color:var(--color-ink); margin-bottom:var(--spacing-sm);">How do I convert a time from one timezone to another?</h3>
          <p style="font-size:15px; color:var(--color-body); line-height:1.6;">Simply select your origin city or timezone in the "From timezone" dropdown and your destination in the "To timezone" dropdown. Then, enter the date and time you wish to convert. The results will update instantly.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:16px; font-weight:600; color:var(--color-ink); margin-bottom:var(--spacing-sm);">Can I convert times for a future or past date, not just right now?</h3>
          <p style="font-size:15px; color:var(--color-body); line-height:1.6;">Yes! Our <strong>time zone converter calculator</strong> allows you to pick any date and time using the calendar picker. This is essential for planning future meetings or checking when a past event occurred.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:16px; font-weight:600; color:var(--color-ink); margin-bottom:var(--spacing-sm);">What does the UTC offset (e.g. UTC+5:30) mean?</h3>
          <p style="font-size:15px; color:var(--color-body); line-height:1.6;">The UTC offset indicates how many hours and minutes a specific location is ahead of (+) or behind (-) Coordinated Universal Time (UTC). For example, UTC+5:30 means the time is 5 hours and 30 minutes ahead of the UTC baseline.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:16px; font-weight:600; color:var(--color-ink); margin-bottom:var(--spacing-sm);">Does the converter automatically account for Daylight Saving Time (DST)?</h3>
          <p style="font-size:15px; color:var(--color-body); line-height:1.6;">Yes, our <strong>world time converter</strong> is DST-aware. When you select a specific date, the tool automatically calculates whether that region is in "Daylight Time" or "Standard Time" for that period.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:16px; font-weight:600; color:var(--color-ink); margin-bottom:var(--spacing-sm);">Why does the time difference between two cities change at certain times of year?</h3>
          <p style="font-size:15px; color:var(--color-body); line-height:1.6;">This usually happens because one city observes Daylight Saving Time while the other does not, or because they transition to/from DST on different dates. This can cause the "offset" between them to shift by one hour.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:16px; font-weight:600; color:var(--color-ink); margin-bottom:var(--spacing-sm);">Which countries don't observe Daylight Saving Time?</h3>
          <p style="font-size:15px; color:var(--color-body); line-height:1.6;">Many countries, especially those near the equator, do not observe DST. Examples include India, China, Japan, and most countries in Africa and South America. In the US, Arizona (mostly) and Hawaii do not observe DST.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:16px; font-weight:600; color:var(--color-ink); margin-bottom:var(--spacing-sm);">What's the difference between UTC and GMT — are they the same thing?</h3>
          <p style="font-size:15px; color:var(--color-body); line-height:1.6;">For most practical purposes, they are the same. However, GMT (Greenwich Mean Time) is a time zone, while UTC (Coordinated Universal Time) is a time standard. UTC does not change for Daylight Saving Time.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:16px; font-weight:600; color:var(--color-ink); margin-bottom:var(--spacing-sm);">Why do some timezones have a half-hour offset, like India (UTC+5:30) or Nepal (UTC+5:45)?</h3>
          <p style="font-size:15px; color:var(--color-body); line-height:1.6;">While most timezones differ by whole hours, some regions choose offsets that better align with their solar time or political boundaries. India uses a 30-minute offset, and Nepal uses a unique 45-minute offset.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:16px; font-weight:600; color:var(--color-ink); margin-bottom:var(--spacing-sm);">What does it mean when the result shows +1 or -1 day?</h3>
          <p style="font-size:15px; color:var(--color-body); line-height:1.6;">This indicates that the converted time falls on the next day (+1) or the previous day (-1) relative to the original time you entered. This is common when converting between distant zones like London and Sydney.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:16px; font-weight:600; color:var(--color-ink); margin-bottom:var(--spacing-sm);">Why can the same abbreviation (like IST or CST) refer to different timezones?</h3>
          <p style="font-size:15px; color:var(--color-body); line-height:1.6;">Abbreviations can be ambiguous. IST can mean India Standard Time, Irish Standard Time, or Israel Standard Time. Our <strong>multiple time zone converter</strong> uses full city/region names to avoid this confusion.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:16px; font-weight:600; color:var(--color-ink); margin-bottom:var(--spacing-sm);">What's the difference between EST and EDT — and when does each apply?</h3>
          <p style="font-size:15px; color:var(--color-body); line-height:1.6;">EST (Eastern Standard Time) applies during winter months, while EDT (Eastern Daylight Time) applies during the summer when Daylight Saving Time is active. Our tool handles this switch automatically for you.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:16px; font-weight:600; color:var(--color-ink); margin-bottom:var(--spacing-sm);">What's the best timezone to use when scheduling meetings with a global team?</h3>
          <p style="font-size:15px; color:var(--color-body); line-height:1.6;">Using a <strong>UTC time zone converter</strong> to set a base time in UTC is often best for global teams. It provides a neutral reference point that everyone can easily convert to their own local time without DST confusion.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── SEO Content Section ─── -->
  <div style="background:var(--color-surface-soft); border-top:1px solid var(--color-hairline-soft); padding:var(--spacing-section) var(--spacing-base);">
    <div style="max-width:var(--width-page); margin:0 auto; color:var(--color-body); line-height:1.8;">
      <h2 style="font-size:24px; font-weight:700; color:var(--color-ink); margin-bottom:var(--spacing-lg);">Why Use Our Time Zone Converter?</h2>
      
      <p style="margin-bottom:var(--spacing-base);">
        Navigating the complexities of global timing can be a daunting task. Whether you're scheduling an international business meeting, planning a call with family across the globe, or coordinating a massive online event, our <strong>time zone converter</strong> is designed to provide you with the accuracy and speed you need. In today's interconnected world, understanding the temporal gap between cities like New York, London, and Tokyo is no longer just a convenience—it's a necessity.
      </p>

      <h3 style="font-size:20px; font-weight:600; color:var(--color-ink); margin-top:var(--spacing-xl); margin-bottom:var(--spacing-md);">A Reliable Time Zone Converter Calculator</h3>
      <p style="margin-bottom:var(--spacing-base);">
        Our tool functions as a sophisticated <strong>time zone converter calculator</strong>. It doesn't just show you the current time in another location; it allows you to pick a specific date and time in the future. This is particularly useful for dealing with Daylight Saving Time (DST) changes, which often occur on different dates in different countries. By using our calculator, you eliminate the risk of "being an hour off"—a common mistake when manually trying to account for DST transitions in regions like Europe or North America.
      </p>

      <h3 style="font-size:20px; font-weight:600; color:var(--color-ink); margin-top:var(--spacing-xl); margin-bottom:var(--spacing-md);">The Efficiency of a World Time Converter</h3>
      <p style="margin-bottom:var(--spacing-base);">
        A true <strong>world time converter</strong> must be comprehensive. That's why we cover over 20 major global time zones, representing the primary hubs of commerce and culture. From the fast-paced markets of Singapore and Hong Kong to the tech centers of San Francisco, our tool ensures you have the right data at your fingertips. If you're a digital nomad or work in a distributed team, you'll appreciate how our <strong>multiple time zone converter</strong> functionality lets you quickly toggle between various destinations, helping you find the perfect "golden hour" where everyone is awake and available for collaboration.
      </p>

      <h3 style="font-size:20px; font-weight:600; color:var(--color-ink); margin-top:var(--spacing-xl); margin-bottom:var(--spacing-md);">Pacific Time Zone Converter & UTC Specialization</h3>
      <p style="margin-bottom:var(--spacing-base);">
        We know that many of our users specifically look for a <strong>pacific time zone converter</strong>. As the home to Hollywood and Silicon Valley, PT (Pacific Time) is one of the most frequently searched zones. Whether you're converting from PST (Standard Time) or PDT (Daylight Time), our tool handles the math for you. Furthermore, for developers, pilots, and military personnel, our <strong>UTC time zone converter</strong> features are indispensable. Using Coordinated Universal Time (UTC) as a baseline is the gold standard for global synchronization, and we make converting from UTC to any local zone as simple as a single click.
      </p>

      <h3 style="font-size:20px; font-weight:600; color:var(--color-ink); margin-top:var(--spacing-xl); margin-bottom:var(--spacing-md);">Key Features of Our Converter</h3>
      <ul style="margin-bottom:var(--spacing-lg); padding-left:var(--spacing-lg); list-style-type: disc;">
        <li style="margin-bottom:var(--spacing-xs);"><strong>Instant Conversion:</strong> Results update as you type, providing immediate feedback.</li>
        <li style="margin-bottom:var(--spacing-xs);"><strong>DST Awareness:</strong> Automatic adjustments for Daylight Saving Time based on the selected date.</li>
        <li style="margin-bottom:var(--spacing-xs);"><strong>Copy to Clipboard:</strong> Easily share the converted time via email, Slack, or calendar invites.</li>
        <li style="margin-bottom:var(--spacing-xs);"><strong>World Clocks:</strong> A quick visual reference for the current time in major cities around the globe.</li>
        <li style="margin-bottom:var(--spacing-xs);"><strong>Clean Interface:</strong> A distraction-free, modern design inspired by top-tier user experience standards.</li>
      </ul>

      <p style="margin-bottom:var(--spacing-base);">
        In conclusion, if you are looking for a fast, free, and accurate way to manage your global schedule, you've found the right place. Our <strong>time zone converter</strong> is optimized for both desktop and mobile use, ensuring that whether you're at your desk or on the go, you'll never be out of sync. Start by picking your origin timezone and destination above, and see how simple world time management can be.
      </p>
    </div>
  </div>

</BaseLayout>

<style>
  .page-link-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-card);
  }
  .page-link-card:hover .link-arrow {
    opacity: 1;
  }
</style>
