---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Contact us" 
  description="Have feedback, a bug report, or a question? We'd love to hear from you."
  keywords="contact timezone converter, support, feedback, bug report, timezone help"
>

  <div style="background:var(--color-surface-soft); border-bottom:1px solid var(--color-hairline-soft); padding:var(--spacing-section) var(--spacing-base);">
    <div style="max-width:var(--width-page); margin:0 auto;">
      <p style="font-size:12px; font-weight:700; color:var(--color-muted); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:var(--spacing-sm);">Page</p>
      <h1 style="font-size:28px; font-weight:700; color:var(--color-ink); line-height:1.43; margin-bottom:var(--spacing-sm);">Get in touch</h1>
      <p style="font-size:16px; color:var(--color-muted); line-height:1.5; max-width:480px;">Have feedback, a bug report, or a question? We'd love to hear from you.</p>
    </div>
  </div>

  <div style="max-width:var(--width-page); margin:0 auto; padding:var(--spacing-section) var(--spacing-base);">
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(300px, 1fr)); gap:var(--spacing-xl);">
      
      {/* Contact Info */}
      <div class="shadow-card" style="background:var(--color-canvas); border:1px solid var(--color-hairline); border-radius:var(--radius-lg); padding:var(--spacing-xl); height:fit-content;">
        <h2 style="font-size:20px; font-weight:700; color:var(--color-ink); margin-bottom:var(--spacing-lg);">Ways to connect</h2>
        
        <div style="display:flex; flex-direction:column; gap:var(--spacing-xl);">
          <div style="display:flex; gap:var(--spacing-md);">
            <div style="width:40px; height:40px; border-radius:var(--radius-sm); background:var(--color-surface-soft); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <p style="font-size:14px; font-weight:600; color:var(--color-ink); margin-bottom:2px;">Email us</p>
              <p style="font-size:14px; color:var(--color-muted);">dhriticodes20@gmail.com</p>
            </div>
          </div>

          <div style="display:flex; gap:var(--spacing-md);">
            <div style="width:40px; height:40px; border-radius:var(--radius-sm); background:var(--color-surface-soft); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/>
              </svg>
            </div>
            <div>
              <p style="font-size:14px; font-weight:600; color:var(--color-ink); margin-bottom:2px;">Twitter / X.com</p>
              <p style="font-size:14px; color:var(--color-muted);">@DhritiBaruah20</p>
            </div>
          </div>

          <div style="display:flex; gap:var(--spacing-md);">
            <div style="width:40px; height:40px; border-radius:var(--radius-sm); background:var(--color-surface-soft); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
            </div>
            <div>
              <p style="font-size:14px; font-weight:600; color:var(--color-ink); margin-bottom:2px;">GitHub</p>
              <p style="font-size:14px; color:var(--color-muted);">https://github.com/dhritich20baruah</p>
            </div>
          </div>
        </div>
      </div>

      {/* Contact Form */}
      <div class="shadow-card" style="background:var(--color-canvas); border:1px solid var(--color-hairline); border-radius:var(--radius-lg); padding:var(--spacing-xl);">
        <h2 style="font-size:20px; font-weight:700; color:var(--color-ink); margin-bottom:var(--spacing-lg);">Send a message</h2>
        <form style="display:flex; flex-direction:column; gap:var(--spacing-base);">
          <div style="display:flex; flex-direction:column; gap:var(--spacing-xs);">
            <label style="font-size:12px; font-weight:600; color:var(--color-muted); text-transform:uppercase;">Name</label>
            <input type="text" placeholder="Your name" style="height:var(--height-btn); border:1px solid var(--color-hairline); border-radius:var(--radius-sm); padding:0 var(--spacing-base); font-size:14px;" />
          </div>
          <div style="display:flex; flex-direction:column; gap:var(--spacing-xs);">
            <label style="font-size:12px; font-weight:600; color:var(--color-muted); text-transform:uppercase;">Email</label>
            <input type="email" placeholder="your@email.com" style="height:var(--height-btn); border:1px solid var(--color-hairline); border-radius:var(--radius-sm); padding:0 var(--spacing-base); font-size:14px;" />
          </div>
          <div style="display:flex; flex-direction:column; gap:var(--spacing-xs);">
            <label style="font-size:12px; font-weight:600; color:var(--color-muted); text-transform:uppercase;">Message</label>
            <textarea rows="4" placeholder="How can we help?" style="border:1px solid var(--color-hairline); border-radius:var(--radius-sm); padding:var(--spacing-base); font-size:14px; resize:none;"></textarea>
          </div>
          <button type="button" style="background:var(--color-rausch); color:white; border:none; border-radius:var(--radius-sm); height:var(--height-btn); font-size:16px; font-weight:600; cursor:pointer; margin-top:var(--spacing-sm);">
            Send message
          </button>
        </form>
      </div>

    </div>
    
    <div style="margin-top:var(--spacing-xl); text-align:center;">
      <a href="/" style="display:inline-flex; align-items:center; gap:8px; color:var(--color-muted); font-size:14px; font-weight:500; text-decoration:none;">
        ← Back to converter
      </a>
    </div>
  </div>

</BaseLayout>
