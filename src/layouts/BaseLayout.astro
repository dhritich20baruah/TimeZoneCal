---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  keywords?: string;
}

const { 
  title, 
  description = 'Convert time between any two timezones instantly.',
  keywords = 'time zone converter, pacific time zone converter, UTC time zone converter, time zone converter calculator, world time converter, multiple time zone converter'
} = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/about',   label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const footerCols = {
  Support: [
    { href: '/contact',        label: 'Contact us' },
    { href: '/privacy-policy', label: 'Privacy policy' },
    { href: '/terms',          label: 'Terms & conditions' },
  ],
  Product: [
    { href: '/',       label: 'Timezone converter' },
    { href: '/about',  label: 'About us' },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={`${title} · Timezone`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/favicon.svg', Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={`${title} · Timezone`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL('/favicon.svg', Astro.url)} />

    <title>{title} · Timezone</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="canonical" href={`https://www.timezonecal.com${Astro.url.pathname}`} />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-ECK9NGSQ0B"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-ECK9NGSQ0B');
    </script>

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
      window.localStorage.setItem('theme', theme);
    </script>
  </head>

  <body>

    <!-- ─── Top Nav ─── -->
    <nav style="background:var(--color-canvas); border-bottom:1px solid var(--color-hairline); height:var(--height-nav);"
         class="flex items-center px-4 lg:px-16 sticky top-0 z-50">
      <div style="max-width:var(--width-content);" class="mx-auto w-full flex items-center justify-between">

        <!-- Wordmark -->
        <a href="/" class="flex items-center gap-2 no-underline">
          <svg width="30" height="30" viewBox="0 0 32 32" fill="var(--color-rausch)" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M16 2C10.477 2 6 6.477 6 12c0 3.537 2.107 7.187 4.688 10.188C12.75 24.5 14.5 26.25 16 27.5c1.5-1.25 3.25-3 5.312-5.312C23.893 19.187 26 15.537 26 12c0-5.523-4.477-10-10-10zm0 13.5a3.5 3.5 0 110-7 3.5 3.5 0 010 7z"/>
          </svg>
          <span style="color:var(--color-rausch); font-size:20px; font-weight:700; letter-spacing:-0.5px; line-height:1;">timezonecal</span>
        </a>

        <!-- Desktop nav links -->
        <div class="hidden sm:flex items-center gap-8">
          {navLinks.map(({ href, label }) => (
            <a
              href={href}
              style={`font-size:16px; font-weight:600; color:${currentPath === href ? 'var(--color-ink)' : 'var(--color-muted)'}; text-decoration:none; padding-bottom:2px; border-bottom:${currentPath === href ? '2px solid var(--color-ink)' : '2px solid transparent'};`}
              class="hover:text-ink transition-colors"
            >
              {label}
            </a>
          ))}
          
          <!-- Theme toggle -->
          <button id="theme-toggle" class="w-10 h-10 rounded-full flex items-center justify-center cursor-pointer transition-colors"
                  style="border:1px solid var(--color-hairline); color:var(--color-muted);"
                  aria-label="Toggle theme">
            <svg id="sun-icon" class="hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <svg id="moon-icon" class="dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </div>

        <!-- Live UTC -->
        <div class="hidden md:block text-right">
          <div style="font-size:12px; font-weight:700; color:var(--color-muted); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:2px;">UTC Now</div>
          <div style="font-size:16px; font-weight:600; color:var(--color-ink); font-variant-numeric:tabular-nums;" id="utc-clock">--:--:--</div>
        </div>

        <!-- Mobile menu button -->
        <div class="flex sm:hidden items-center gap-2">
          <button id="mobile-theme-toggle" class="w-10 h-10 rounded-full flex items-center justify-center"
                  style="border:1px solid var(--color-hairline); color:var(--color-muted);"
                  aria-label="Toggle theme">
            <svg class="hidden dark:block" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
            </svg>
            <svg class="dark:hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
          <button id="menu-btn" class="w-10 h-10 rounded-full flex items-center justify-center"
                  style="border:1px solid var(--color-hairline); color:var(--color-muted);"
                  aria-label="Menu">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="2" y1="4" x2="14" y2="4"/><line x1="2" y1="8" x2="14" y2="8"/><line x1="2" y1="12" x2="14" y2="12"/>
            </svg>
          </button>
        </div>

      </div>
    </nav>

    <!-- Mobile Drawer Overlay -->
    <div id="drawer-backdrop" class="fixed inset-0 bg-black/50 z-60 opacity-0 pointer-events-none transition-opacity duration-300"></div>
    <div id="mobile-drawer" class="fixed top-0 right-0 bottom-0 w-70 bg-[var(--color-canvas)] z-70 translate-x-full transition-transform duration-300 shadow-xl flex flex-col">
      <div class="p-6 border-bottom-[1px] border-[var(--color-hairline)] flex items-center justify-between">
        <span style="color:var(--color-rausch); font-size:20px; font-weight:700; letter-spacing:-0.5px;">timezonecal</span>
        <button id="close-drawer" class="w-10 h-10 rounded-full flex items-center justify-center" style="border:1px solid var(--color-hairline); color:var(--color-muted);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <div class="flex-1 overflow-y-auto p-6 flex flex-col gap-6">
        <div class="flex flex-col gap-4">
          <a href="/" class="text-[18px] font-semibold no-underline" style={`color:${currentPath === '/' ? 'var(--color-rausch)' : 'var(--color-ink)'}`}>Home</a>
          {navLinks.map(({ href, label }) => (
            <a href={href} class="text-[18px] font-semibold no-underline" style={`color:${currentPath === href ? 'var(--color-rausch)' : 'var(--color-ink)'}`}>{label}</a>
          ))}
        </div>
        <div class="mt-auto pt-6 border-t border-[var(--color-hairline-soft)]">
          <div style="font-size:12px; font-weight:700; color:var(--color-muted); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">Current Time</div>
          <div style="font-size:20px; font-weight:700; color:var(--color-ink); font-variant-numeric:tabular-nums;" id="utc-clock-mobile">--:--:--</div>
        </div>
      </div>
    </div>

    <!-- ─── Page content ─── -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- ─── Footer ─── -->
    <footer style="background:var(--color-canvas); border-top:1px solid var(--color-hairline); margin-top:auto;">
      <div style="max-width:var(--width-content); padding:var(--spacing-xxl) var(--spacing-base);" class="mx-auto">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
          {Object.entries(footerCols).map(([heading, links]) => (
            <div>
              <h3 style="font-size:16px; font-weight:500; color:var(--color-ink); margin-bottom:var(--spacing-md);">{heading}</h3>
              <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:var(--spacing-sm);">
                {links.map(({ href, label }) => (
                  <li>
                    <a href={href} style="font-size:14px; color:var(--color-ink); text-decoration:none;" class="hover:underline">{label}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- Legal band -->
      <div style="border-top:1px solid var(--color-hairline-soft); padding:var(--spacing-base);">
        <div style="max-width:var(--width-content);" class="mx-auto flex flex-col sm:flex-row items-center justify-between gap-2">
          <span style="font-size:13px; color:var(--color-muted);">© {new Date().getFullYear()} Timezone Converter, Inc.</span>
          <div class="flex items-center gap-4">
            {[
              { href: '/privacy-policy', label: 'Privacy' },
              { href: '/terms',          label: 'Terms' },
            ].map(({ href, label }) => (
              <a href={href} style="font-size:13px; color:var(--color-muted); text-decoration:none;" class="hover:underline">{label}</a>
            ))}
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>

<script>
  // --- UTC Clock ---
  function tickUTC() {
    const clockDesktop = document.getElementById('utc-clock');
    const clockMobile = document.getElementById('utc-clock-mobile');
    const timeStr = new Intl.DateTimeFormat('en-US', {
      timeZone: 'UTC', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false,
    }).format(new Date()) + ' UTC';
    
    if (clockDesktop) clockDesktop.textContent = timeStr;
    if (clockMobile) clockMobile.textContent = timeStr;
  }
  tickUTC();
  setInterval(tickUTC, 1000);

  // --- Theme Toggle ---
  const themeToggle = document.getElementById('theme-toggle');
  const mobileThemeToggle = document.getElementById('mobile-theme-toggle');
  
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");

    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  };

  themeToggle?.addEventListener("click", handleToggleClick);
  mobileThemeToggle?.addEventListener("click", handleToggleClick);

  // --- Mobile Drawer ---
  const menuBtn = document.getElementById('menu-btn');
  const closeBtn = document.getElementById('close-drawer');
  const drawer = document.getElementById('mobile-drawer');
  const backdrop = document.getElementById('drawer-backdrop');

  function openDrawer() {
    drawer?.classList.remove('translate-x-full');
    backdrop?.classList.remove('opacity-0', 'pointer-events-none');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer?.classList.add('translate-x-full');
    backdrop?.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
  }

  menuBtn?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);
</script>
